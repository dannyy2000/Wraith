# Deployer
PRIVATE_KEY=0x...

# RPC endpoints
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Block explorer verification
ARBISCAN_API_KEY=...

# Chainlink CRE Forwarder — set this to the address for your target chain
# Arbitrum Sepolia: check https://docs.chain.link/cre for the current address
CRE_FORWARDER_ADDRESS=0x...

# Populated after deployment (used by CRE workflows and frontend)
MARKET_FACTORY_ADDRESS=
PRIVACY_POOL_ADDRESS=
CLAIM_REGISTRY_ADDRESS=
# Register this address at automation.chain.link to activate the keeper
WRAITH_KEEPER_ADDRESS=
