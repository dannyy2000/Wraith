# Copy to secrets.yaml and fill in your values.
# Upload with: cre secrets create secrets.yaml --target staging-settings
# Actual values go in .env (also gitignored). secrets.yaml is never committed.

secretsNames:
  OPENAI_API_KEY:
    - OPENAI_API_KEY_VAR     # set OPENAI_API_KEY_VAR=sk-... in .env
  NEWS_API_KEY:
    - NEWS_API_KEY_VAR       # set NEWS_API_KEY_VAR=... in .env
